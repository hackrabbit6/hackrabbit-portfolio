---
import Base from '../layouts/Base.astro'
---

<Base>
  <main class="shell">
    <p class="eyebrow">cinematic-v2 / phase 1</p>
    <h1>hackrabbit cinematic homepage</h1>
  </main>
</Base>

<style>
  .shell {
    display: grid;
    min-height: 140vh;
    padding: var(--s8) max(var(--s5), calc((100vw - 1180px) / 2 + var(--s5)));
    place-content: start;
  }

  .eyebrow {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 13px;
    margin: 0 0 var(--s4);
    text-transform: uppercase;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(48px, 10vw, 120px);
    line-height: 0.95;
    margin: 0;
  }
</style>
